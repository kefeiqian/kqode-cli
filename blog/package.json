{
  "name": "@kqode/blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "node ./node_modules/@docusaurus/core/bin/docusaurus.mjs build",
    "clear": "node ./node_modules/@docusaurus/core/bin/docusaurus.mjs clear",
    "serve": "node ./node_modules/@docusaurus/core/bin/docusaurus.mjs start --host 127.0.0.1 --port 3000",
    "serve:en": "node ./node_modules/@docusaurus/core/bin/docusaurus.mjs start --locale en --host 127.0.0.1 --port 3000",
    "dev": "node ./scripts/dev-server.mjs",
    "preview": "node ./node_modules/@docusaurus/core/bin/docusaurus.mjs serve --dir build --host 127.0.0.1 --port 3000 --build",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.11",
    "lucide-react": "^1.21.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@tailwindcss/postcss": "^4.3.1",
    "chokidar": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3"
  }
}
