# Local reference-implementation mirror for the kqode-research skill.
# Keep the directory tracked via .gitkeep so /kqode-research has a stable mirror
# location on fresh clones, but never commit the untrusted mirror contents.
/docs/claude-code/*
!/docs/claude-code/.gitkeep

# Local environment and logs
.env
.env.*
!.env.example
*.log

# Editor and local workspace state
.idea/
.vscode/
.obsidian/*
