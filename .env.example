# Kimi / Moonshot provider configuration for the KQode Rust backend.
# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#
# NOTE: The TUI `/login` command stores keys in your OS keychain (preferred,
# user-global across workspaces) and is the recommended way to configure
# providers. This `.env` is a workspace-scoped fallback for the Kimi key only;
# when both exist, the keychain key takes precedence. The SQLite index lives at
# ~/.kqode/kqode.db (override with KQODE_DB_PATH); it never stores key material.

# Required: your Kimi/Moonshot API key. Leave blank to disable the provider
# (the backend then reports "needsConfiguration" instead of calling out).
KIMI_API_KEY=

# Model id. Default: kimi-k2.7-code. Alternate: kimi-k2.6 (both 256k context).
KIMI_MODEL=kimi-k2.7-code

# API base URL. Default targets Moonshot China (CNY billing).
# International keys use https://api.moonshot.ai/v1
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: force LLM request/response logging to ~/.kqode/logs/. Logging is ON
# by default in dev builds and OFF in packaged builds; uncomment to force it on
# (dist opt-in), or set to 0 to turn it off in dev. The TUI `--debug` flag sets
# this for you. The API key is never written to the logs.
# KQODE_DEBUG=1
