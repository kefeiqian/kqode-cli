# Custom provider configuration for the KQode Rust backend.
# Copy this file to `.env` and fill in your values. `.env` is gitignored.
#
# The `.env` file configures the user-supplied **Custom** provider: any
# OpenAI-compatible endpoint (including Kimi/Moonshot). The built-in Kimi preset
# is configured through the TUI `/login` command (OS keychain) only and never
# reads the environment.
#
# NOTE: `/login` stores keys in your OS keychain (preferred, user-global across
# workspaces). This `.env` is a workspace-scoped fallback; when both exist, a
# keychain key takes precedence. The SQLite index lives at ~/.kqode/kqode.db;
# it never stores key material.

# Required: your Custom provider API key. Leave blank to disable the provider
# (the backend then reports "needsConfiguration" instead of calling out).
CUSTOM_API_KEY=

# Required: the model id sent to the Custom endpoint (e.g. kimi-k2.7-code).
CUSTOM_MODEL=

# Required: the OpenAI-compatible base URL. Must be https. For Kimi/Moonshot use
# https://api.moonshot.cn/v1 (CNY billing) or https://api.moonshot.ai/v1.
CUSTOM_BASE_URL=

# Optional: force LLM request/response logging to ~/.kqode/logs/. Logging is ON
# by default in dev builds and OFF in packaged builds; uncomment to force it on
# (dist opt-in), or set to 0 to turn it off in dev. The TUI `--debug` flag sets
# this for you. The API key is never written to the logs.
# KQODE_DEBUG=1
