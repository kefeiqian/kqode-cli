# Ensure shell scripts always use LF so they run on Unix and in Git Bash,
# even when checked out on Windows.
*.sh text eol=lf

# Pin SQL migrations to LF on every platform. refinery hashes the working-tree
# bytes of each embedded migration, so a CRLF checkout on Windows would diverge
# from the LF-computed checksum pinned in the store tests.
*.sql text eol=lf
